# ============================================
# PrepareAI Environment Variables
# Copy to .env.local and fill in values
# ============================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/prepareai
DIRECT_URL=postgresql://postgres:password@localhost:5432/prepareai

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=run-this-to-generate: openssl rand -base64 32

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-5-20251001

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# File Storage
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=prepareai-uploads

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=royvivasi@gmail.com
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60
